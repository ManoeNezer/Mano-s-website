let aiHist = [];
let aiIsLoading = false;

async function aiSend() {

  const inp = document.getElementById('aiIn');
  const txt = inp.value.trim();

  if (!txt || aiIsLoading) return;

  if (txt.toLowerCase().startsWith('/img ')) {

    const p = txt.replace('/img ', '').trim();

    addAmsg('user', txt);

    inp.value = '';

    aiIsLoading = true;

    const ld = addAmsg(
      'ai loading',
      '<div class="spinner"></div><span style="margin-left:10px"></span>'
    );

    const url =
      `https://image.pollinations.ai/prompt/${encodeURIComponent(p)}?width=1024&height=1024&nologo=true&seed=${Math.floor(Math.random()*1000)}`;

    const img = new Image();

    img.src = url;

    img.onload = () => {

      ld.classList.remove('loading');

      ld.innerHTML = `
        <img src="${url}" style="width:100%;border-radius:12px;border:1px solid rgba(255,255,255,0.1)">
        <p style="font-size:.7rem;opacity:.6;margin-top:5px">
          ✨ ${p}
        </p>
      `;

    };

    img.onerror = () => {

      ld.innerHTML = '❌ Erreur génération image.';

    };

    aiIsLoading = false;

    return;

  }

  addAmsg('user', txt);

  inp.value = '';

  aiIsLoading = true;

  const ld = addAmsg(
    'ai loading',
    '<div class="spinner"></div>'
  );

  try {

    const modelId =
      document.getElementById('aiModel').value;

    const contents = [

      ...aiHist,

      {
        role: "user",
        parts: [
          {
            text: txt
          }
        ]
      }

    ];

    const response = await fetch('/api/chat', {

      method: 'POST',

      headers: {
        'Content-Type': 'application/json'
      },

      body: JSON.stringify({
        model: modelId,
        contents: contents
      })

    });

    const data = await response.json();

    if (
      data.candidates &&
      data.candidates[0].content
    ) {

      const aiText =
        data.candidates[0]
        .content.parts[0].text;

      aiHist.push({
        role: "user",
        parts: [{ text: txt }]
      });

      aiHist.push({
        role: "model",
        parts: [{ text: aiText }]
      });

      ld.classList.remove('loading');

      ld.innerHTML =
        aiText
        .replace(/\*\*(.*?)\*\*/g,
          '<strong>$1</strong>')
        .replace(/\n/g, '<br>')
        .replace(/`([^`]+)`/g,
          '<code style="background:rgba(0,0,0,0.3);padding:2px 4px;border-radius:4px">$1</code>');

    } else {

      throw new Error(
        data.error?.message ||
        "Réponse vide"
      );

    }

  } catch (e) {

    ld.classList.remove('loading');

    ld.innerHTML =
      `<span style="color:#ff6b6b">
        ❌ ${e.message}
      </span>`;

  }

  finally {

    aiIsLoading = false;

    const cont =
      document.getElementById('aiMsgs');

    cont.scrollTop =
      cont.scrollHeight;

  }

}

