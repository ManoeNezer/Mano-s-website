    }));
    dots.forEach(d=>{ctx.fillStyle='rgba(255,255,255,0.7)';ctx.beginPath();ctx.arc((d.x+.5)*TILE,(d.y+.5)*TILE,2.5,0,Math.PI*2);ctx.fill();});
    // pacman
    const mouthAng=(Math.sin(frame/3)+1)*0.15+0.05;
    ctx.fillStyle='#facc15';ctx.shadowColor='#facc15';ctx.shadowBlur=8;
    ctx.beginPath();ctx.moveTo((px+.5)*TILE,(py+.5)*TILE);
    ctx.arc((px+.5)*TILE,(py+.5)*TILE,TILE/2-2,mouthAng,Math.PI*2-mouthAng);ctx.closePath();ctx.fill();ctx.shadowBlur=0;
    // ghosts
    ghosts.forEach(g=>{
      ctx.font='16px serif';ctx.textAlign='center';
      ctx.fillText('👻',(g.x+.5)*TILE,(g.y+.5)*TILE+6);
    });
    // HUD
    ctx.fillStyle='white';ctx.font='12px Space Mono,monospace';ctx.textAlign='left';ctx.fillText('Score: '+score,4,12);
    ctx.textAlign='right';ctx.fillText('❤'.repeat(lives),COLS*TILE-4,12);
  }
  startRafLoop(loop,60);
}

