        if(!br.alive)return;
        if(bx>br.x-BR&&bx<br.x+br.w+BR&&by>br.y-BR&&by<br.y+br.h+BR){
          br.alive=false;bdy=-bdy;score+=10;
          if(bricks.every(b=>!b.alive)){makeBricks();toast('🎉 +1 niveau!');const spd=Math.sqrt(bdx*bdx+bdy*bdy);const ncap=Math.min(spd*1.06,4.4);bdx=bdx/spd*ncap;bdy=bdy/spd*ncap;}
        }
      });
    }
    bricks.forEach(b=>{if(!b.alive)return;ctx.fillStyle=b.c;ctx.shadowColor=b.c;ctx.shadowBlur=6;ctx.beginPath();ctx.roundRect(b.x,b.y,b.w,b.h,4);ctx.fill();ctx.shadowBlur=0;});
    ctx.fillStyle=ac;ctx.shadowColor=ac;ctx.shadowBlur=8;ctx.beginPath();ctx.roundRect(px,H-PH-10,PW,PH,4);ctx.fill();ctx.shadowBlur=0;
    ctx.beginPath();ctx.arc(bx,by,BR,0,Math.PI*2);ctx.fillStyle='white';ctx.shadowColor='white';ctx.shadowBlur=10;ctx.fill();ctx.shadowBlur=0;
    ctx.fillStyle='white';ctx.font='13px Space Mono,monospace';ctx.textAlign='left';ctx.fillText('Score: '+score,8,18);
    ctx.textAlign='right';ctx.fillText('❤'.repeat(lives),W-8,18);
  }
  startRafLoop(loop,60);gameKeyHandler=e=>{if(e.key==='ArrowLeft')px=Math.max(0,px-16);if(e.key==='ArrowRight')px=Math.min(W-PW,px+16);if(e.key===' '){e.preventDefault();startBreakout();}};
  document.addEventListener('keydown',gameKeyHandler);
  addGameControls(wrap,{actions:[{label:'Lancer',key:' '}],pause:false});
}

// ===== FLAPPY BIRD =====
function launchFlappy(wrap){
  const W=360,H=480;
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='🐤 Flappy Bird';wrap.appendChild(titleEl);
  const canvas=document.createElement('canvas');canvas.width=W;canvas.height=H;wrap.appendChild(canvas);
  const ctx=canvas.getContext('2d');
  const hint=document.createElement('div');hint.style.cssText='font-size:.75rem;color:var(--text-dim);margin-top:8px;';hint.innerText='Espace / Clic = Sauter';wrap.appendChild(hint);
  let by=H/2,vel=0,pipes=[],score=0,frame=0,running=false,started=false;
  const GRAVITY=0.45,JUMP=-8,GAP=140,PW=52;
  function jump(){if(!started){started=true;running=true;}if(running)vel=JUMP;}
  gameKeyHandler=e=>{if(e.key===' '){e.preventDefault();jump();}};
  document.addEventListener('keydown',gameKeyHandler);
  canvas.addEventListener('click',jump);
  addActionControl(wrap,'Sauter',' ');
  function loop(){
    ctx.fillStyle='#0a0e1a';ctx.fillRect(0,0,W,H);
    const ac=getComputedStyle(document.body).getPropertyValue('--accent').trim()||'#4f96ff';
    if(!started){ctx.fillStyle='rgba(255,255,255,0.7)';ctx.font='bold 16px Syne,sans-serif';ctx.textAlign='center';ctx.fillText('Espace ou Clic pour démarrer',W/2,H/2);}
    if(running){
      frame++;vel+=GRAVITY;by+=vel;
      if(frame%80===0){const th=60+Math.random()*(H-GAP-120);pipes.push({x:W,top:th,scored:false});}
      pipes=pipes.filter(p=>p.x>-PW);
      pipes.forEach(p=>{p.x-=3;if(!p.scored&&p.x<60){p.scored=true;score++;}});
      if(by<10||by>H-20){running=false;toast('Game Over · '+score);return;}
      pipes.forEach(p=>{if(60>p.x-PW/2&&60<p.x+PW/2&&(by<p.top||by>p.top+GAP)){running=false;toast('Game Over · '+score);}});
    }
    pipes.forEach(p=>{
      ctx.fillStyle='#22c55e';ctx.shadowColor='#22c55e';ctx.shadowBlur=8;
      ctx.beginPath();ctx.roundRect(p.x-PW/2,0,PW,p.top,4);ctx.fill();
      ctx.beginPath();ctx.roundRect(p.x-PW/2,p.top+GAP,PW,H-p.top-GAP,4);ctx.fill();ctx.shadowBlur=0;
    });
    ctx.font='24px serif';ctx.textAlign='center';ctx.fillText('🐤',60,by+8);
    ctx.fillStyle='white';ctx.font='bold 20px Space Mono,monospace';ctx.fillText(score,W/2,30);
  }
  startRafLoop(loop,60);
}

// ===== 2048 =====
function launch2048(wrap){
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='🔢 2048';wrap.appendChild(titleEl);
  let grid,score;
  const container=document.createElement('div');container.style.cssText='display:flex;flex-direction:column;align-items:center;gap:12px;';
  container.className='g2048-container';
  const scoreEl=document.createElement('div');scoreEl.style.cssText='font-family:"Space Mono",monospace;font-size:1.1rem;color:var(--accent);';
  const boardEl=document.createElement('div');boardEl.style.cssText='display:grid;grid-template-columns:repeat(4,80px);gap:8px;background:rgba(0,0,0,0.3);padding:12px;border-radius:16px;';
  boardEl.className='g2048-board';
  const resetBtn=document.createElement('button');resetBtn.className='btn ac';resetBtn.innerText='↺ Nouvelle partie';resetBtn.onclick=init;
  container.appendChild(scoreEl);container.appendChild(boardEl);container.appendChild(resetBtn);wrap.appendChild(container);
  const COLORS={'2':'#eee8d5','4':'#ede0c8','8':'#f2b179','16':'#f59563','32':'#f67c5f','64':'#f65e3b','128':'#edcf72','256':'#edcc61','512':'#edc850','1024':'#edc53f','2048':'#edc22e'};
  function init(){grid=Array.from({length:4},()=>Array(4).fill(0));score=0;addTile();addTile();render();}
  function addTile(){const empty=[];grid.forEach((row,r)=>row.forEach((v,c)=>{if(!v)empty.push([r,c]);}));if(!empty.length)return;const[r,c]=empty[Math.floor(Math.random()*empty.length)];grid[r][c]=Math.random()<.9?2:4;}
  function render(){
    scoreEl.innerText='Score: '+score;boardEl.innerHTML='';
    grid.forEach(row=>row.forEach(v=>{
      const cell=document.createElement('div');
      cell.className='g2048-cell';
      cell.style.cssText=`width:80px;height:80px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:"Space Mono",monospace;font-weight:700;font-size:${v>999?'1rem':'1.3rem'};background:${COLORS[v]||'var(--accent)'};color:${v>4?'#776e65':'#f9f6f2'};transition:all .1s;`;
      cell.innerText=v||'';boardEl.appendChild(cell);
    }));
  }
  function move(dir){
    let moved=false;
    const slide=row=>{let arr=row.filter(v=>v);for(let i=0;i<arr.length-1;i++){if(arr[i]===arr[i+1]){arr[i]*=2;score+=arr[i];arr.splice(i+1,1);}}while(arr.length<4)arr.push(0);if(arr.join()!==row.join())moved=true;return arr;};
    for(let r=0;r<4;r++){
      if(dir==='left')grid[r]=slide(grid[r]);
      if(dir==='right')grid[r]=slide([...grid[r]].reverse()).reverse();
    }
    if(dir==='up'||dir==='down'){
      for(let c=0;c<4;c++){
        let col=grid.map(r=>r[c]);
        if(dir==='down')col=col.reverse();
        col=slide(col);if(dir==='down')col=col.reverse();
        grid.forEach((r,i)=>r[c]=col[i]);
      }
    }
    if(moved){addTile();render();if(grid.flat().includes(2048))toast('🎉 2048 !');}
  }
  gameKeyHandler=e=>{
    const map={ArrowLeft:'left',ArrowRight:'right',ArrowUp:'up',ArrowDown:'down'};
    if(map[e.key]){e.preventDefault();move(map[e.key]);}
  };
  document.addEventListener('keydown',gameKeyHandler);
  addGameControls(wrap,{pause:false});
  init();
}

// ===== MEMORY =====
function launchMemory(wrap){
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='🃏 Memory';wrap.appendChild(titleEl);
  const EMOJIS=['🎮','🎯','🎲','🎸','🎺','🎨','🌈','💎','🔮','🚀','🌙','⚡'];
  let cards,flipped=[],matched=0,moves=0,canFlip=true;
  const statsEl=document.createElement('div');statsEl.style.cssText='font-size:.82rem;color:var(--text-dim);margin-bottom:10px;';
  const boardEl=document.createElement('div');boardEl.style.cssText='display:grid;grid-template-columns:repeat(6,1fr);gap:8px;max-width:400px;';
  boardEl.className='memory-board';
  const resetBtn=document.createElement('button');resetBtn.className='btn ac';resetBtn.style.marginTop='12px';resetBtn.innerText='↺ Nouvelle partie';resetBtn.onclick=init;
  wrap.appendChild(statsEl);wrap.appendChild(boardEl);wrap.appendChild(resetBtn);
  function init(){
    const pairs=[...EMOJIS,...EMOJIS].sort(()=>Math.random()-.5);
    cards=pairs.map((e,i)=>({id:i,emoji:e,flipped:false,matched:false}));
    flipped=[];matched=0;moves=0;canFlip=true;render();
  }
  function render(){
    statsEl.innerText=`Coups: ${moves} · Paires: ${matched}/${EMOJIS.length}`;
    boardEl.innerHTML='';
    cards.forEach(card=>{
      const el=document.createElement('div');
      el.className='memory-cell';
      el.style.cssText=`width:58px;height:58px;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:1.5rem;cursor:pointer;transition:all .3s cubic-bezier(.34,1.56,.64,1);border:1px solid rgba(255,255,255,${card.flipped||card.matched?.2:.08});background:rgba(255,255,255,${card.flipped||card.matched?.1:.05});${card.matched?'opacity:.6':''};`;
      el.innerText=card.flipped||card.matched?card.emoji:'';
      if(!card.matched&&!card.flipped)el.onclick=()=>flip(card);
      boardEl.appendChild(el);
    });
    if(matched===EMOJIS.length)toast('🎉 Gagné en '+moves+' coups !');
  }
  function flip(card){
    if(!canFlip||card.flipped)return;
    card.flipped=true;flipped.push(card);render();
    if(flipped.length===2){moves++;canFlip=false;
    setTimeout(()=>{
      if(flipped[0].emoji===flipped[1].emoji){flipped.forEach(c=>c.matched=true);matched++;}
      flipped.forEach(c=>{if(!c.matched)c.flipped=false;});
      flipped=[];canFlip=true;render();
    },900);}
  }
  init();gameKeyHandler=()=>{};
}

// ===== DINO RUN =====
function launchDino(wrap){
  const W=480,H=200;
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='🦕 Dino Run';wrap.appendChild(titleEl);
  const canvas=document.createElement('canvas');canvas.width=W;canvas.height=H;canvas.style.borderRadius='14px';wrap.appendChild(canvas);
  const ctx=canvas.getContext('2d');
  const hint=document.createElement('div');hint.style.cssText='font-size:.75rem;color:var(--text-dim);margin-top:8px;';hint.innerText='Espace / Clic = Sauter';wrap.appendChild(hint);
  let dy=H-50,vel=0,cacti=[],score=0,speed=4,frame=0,running=false,started=false;
  const GROUND=H-30,JUMP=-12,DINO_H=40;
  function jump(){if(!started){started=true;running=true;}if(dy>=GROUND-DINO_H&&running)vel=JUMP;}
  gameKeyHandler=e=>{if(e.key===' '){e.preventDefault();jump();}};
  document.addEventListener('keydown',gameKeyHandler);
  canvas.addEventListener('click',jump);
  addActionControl(wrap,'Sauter',' ');
  function loop(){
    ctx.fillStyle='#0a0e1a';ctx.fillRect(0,0,W,H);
    const ac=getComputedStyle(document.body).getPropertyValue('--accent').trim()||'#4f96ff';
    // ground
    ctx.strokeStyle='rgba(255,255,255,0.15)';ctx.lineWidth=1;ctx.beginPath();ctx.moveTo(0,GROUND);ctx.lineTo(W,GROUND);ctx.stroke();
    if(!started){ctx.fillStyle='rgba(255,255,255,0.7)';ctx.font='bold 14px Syne,sans-serif';ctx.textAlign='center';ctx.fillText('Espace ou Clic pour démarrer',W/2,H/2);}
    if(running){
      frame++;score++;speed=4+Math.floor(score/300)*0.4;speed=Math.min(speed,8);
      vel+=0.7;dy+=vel;if(dy>GROUND-DINO_H){dy=GROUND-DINO_H;vel=0;}
      if(frame%Math.max(60,100-Math.floor(score/200)*5)===0)cacti.push({x:W,w:18+Math.random()*14,h:30+Math.random()*20});
      cacti=cacti.filter(c=>c.x>-30);cacti.forEach(c=>{c.x-=speed;});
      cacti.forEach(c=>{if(50>c.x-8&&50<c.x+c.w+8&&dy+DINO_H>GROUND-c.h){running=false;toast('Game Over · Score: '+Math.floor(score/10));}});
    }
    // dino
    ctx.font='32px serif';ctx.textAlign='center';ctx.fillText('🦕',50,dy+DINO_H);
    // cacti
    cacti.forEach(c=>{ctx.fillStyle='#22c55e';ctx.shadowColor='#22c55e';ctx.shadowBlur=6;ctx.beginPath();ctx.roundRect(c.x,GROUND-c.h,c.w,c.h,2);ctx.fill();ctx.shadowBlur=0;});
    // score
    ctx.fillStyle='rgba(255,255,255,0.6)';ctx.font='13px Space Mono,monospace';ctx.textAlign='right';ctx.fillText(Math.floor(score/10),W-10,18);
    if(!running&&started){ctx.fillStyle='rgba(255,255,255,0.8)';ctx.font='bold 18px Syne,sans-serif';ctx.textAlign='center';ctx.fillText('Game Over — Clic pour rejouer',W/2,H/2);}
  }
  canvas.addEventListener('click',()=>{if(!running&&started){dy=H-50;vel=0;cacti=[];score=0;speed=4;frame=0;running=true;}});
  startRafLoop(loop,60);
}

