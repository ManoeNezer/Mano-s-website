let pgCurrentTab = 'html';
let pgLiveTimer = null;
let pgDeviceMode = 'desktop';

function pgBridgeScript(){
  return `<script>
  (() => {
    const pack = value => {
      try {
        if (value instanceof Error) return value.message;
        if (typeof value === 'object') return JSON.stringify(value, null, 2);
        return String(value);
      } catch {
        return String(value);
      }
    };
    const send = (level, args) => parent.postMessage({ type:'pg-log', level, args: args.map(pack) }, '*');
    ['log','warn','error'].forEach(level => {
      const original = console[level];
      console[level] = (...args) => {
        send(level, args);
        if (original) original.apply(console, args);
      };
    });
    window.addEventListener('error', e => send('error', [e.message + ' @ ' + e.lineno + ':' + e.colno]));
    window.addEventListener('unhandledrejection', e => send('error', [e.reason || 'Promise rejetée']));
  })();
  <\/script>`;
}

function pgClearConsole(){
  const el=document.getElementById('pgConsole');
  if(el)el.innerHTML='';
}

function pgAddLog(level,args){
  const el=document.getElementById('pgConsole');
  if(!el)return;
  const row=document.createElement('div');
  row.className='pg-log '+level;
  row.textContent=(level==='log'?'':level.toUpperCase()+': ')+args.join(' ');
  el.appendChild(row);
  el.scrollTop=el.scrollHeight;
}

window.addEventListener('message',e=>{
  if(!e.data||e.data.type!=='pg-log')return;
  pgAddLog(e.data.level,e.data.args||[]);
});

function pgDevice(mode){
  pgDeviceMode=mode;
  const frame=document.getElementById('pgFrame');
  frame.classList.remove('device-tablet','device-mobile');
  if(mode!=='desktop')frame.classList.add('device-'+mode);
}

function pgTab(tab, el) {
  pgCurrentTab = tab;
  document.querySelectorAll('.ntab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.pg-ta').forEach(t => t.classList.remove('active'));
  if(el) el.classList.add('active');
  const snips = document.getElementById('pg-snippets');
  if(tab === 'snippets') {
    document.querySelectorAll('.pg-ta').forEach(t => t.style.display = 'none');
    snips.style.display = 'flex';
    pgBuildSnippets();
  } else {
    document.querySelectorAll('.pg-ta').forEach(t => t.style.display = '');
    snips.style.display = 'none';
    document.getElementById('pg-'+tab).classList.add('active');
  }
  pgUpdateFooter();
}

function pgBuildSnippets() {
  const el = document.getElementById('pg-snippets');
  el.innerHTML = '';
  PG_SNIPPETS.forEach((s, i) => {
    const d = document.createElement('div');
    d.className = 'pg-snip';
    d.innerHTML = `<h5>${s.name}</h5><p>${s.desc}</p>`;
    d.onclick = () => {
      document.getElementById('pg-html').value = s.html;
      document.getElementById('pg-css').value = s.css;
      document.getElementById('pg-js').value = s.js;
      pgTab('html', document.querySelectorAll('.ntab')[0]);
      pgRun();
      toast('Exemple chargé: ' + s.name);
    };
    el.appendChild(d);
  });
}

function pgLiveRun() {
  clearTimeout(pgLiveTimer);
  pgLiveTimer = setTimeout(pgRun, 380);
}

function pgRun() {
  const html = document.getElementById('pg-html').value;
  const css = document.getElementById('pg-css').value;
  const js = document.getElementById('pg-js').value;
  pgClearConsole();
  const doc = `<!DOCTYPE html><html><head><meta charset="UTF-8"><style>${css}</style></head><body>${html}${pgBridgeScript()}<script>${js}<\/script></body></html>`;
  const frame = document.getElementById('pgFrame');
  frame.srcdoc = doc;
  pgDevice(pgDeviceMode);
}

function pgReset(silent=false) {
  document.getElementById('pg-html').value = PG_DEFAULT.html;
  document.getElementById('pg-css').value = PG_DEFAULT.css;
  document.getElementById('pg-js').value = PG_DEFAULT.js;
  pgRun(); pgUpdateFooter(); if(!silent)toast('Code réinitialisé');
}

function pgCopy() {
  const ta = document.getElementById('pg-' + (pgCurrentTab === 'snippets' ? 'html' : pgCurrentTab));
  navigator.clipboard.writeText(ta.value).then(() => toast('Code copié ✓'));
}

function pgDownload() {
  const html = document.getElementById('pg-html').value;
  const css = document.getElementById('pg-css').value;
  const js = document.getElementById('pg-js').value;
  const doc = `<!DOCTYPE html>\n<html>\n<head>\n<meta charset="UTF-8">\n<style>\n${css}\n</style>\n</head>\n<body>\n${html}\n<script>\n${js}\n<\/script>\n</body>\n</html>`;
  const a = document.createElement('a');
  a.href = 'data:text/html;charset=utf-8,' + encodeURIComponent(doc);
  a.download = 'playground.html';
  a.click();
  toast('→ playground.html téléchargé');
}

function pgFullscreen() {
  const frame = document.getElementById('pgFrame');
  if(frame.requestFullscreen) frame.requestFullscreen();
  else if(frame.webkitRequestFullscreen) frame.webkitRequestFullscreen();
}

function pgUpdateFooter() {
  const tab = pgCurrentTab === 'snippets' ? 'html' : pgCurrentTab;
  const val = document.getElementById('pg-' + tab).value;
  const lines = val.split('\n').length;
  const size = new Blob([val]).size;
  document.getElementById('pg-lines').innerText = lines + ' lignes';
  document.getElementById('pg-size').innerText = size > 1024 ? (size/1024).toFixed(1)+'KB' : size+'B';
}

function pgTabIndent(e) {
  if(e.key === 'Tab') {
    e.preventDefault();
    const ta = e.target;
    const start = ta.selectionStart, end = ta.selectionEnd;
    ta.value = ta.value.substring(0,start) + '  ' + ta.value.substring(end);
    ta.selectionStart = ta.selectionEnd = start + 2;
    pgLiveRun();
  }
}

