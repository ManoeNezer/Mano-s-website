function bindGameButton(btn,key,hold){
  let pressed=false;
  const down=e=>{
    e.preventDefault();
    if(pressed)return;
    pressed=true;
    gameKey(key,'keydown');
    if(!hold)setTimeout(()=>{gameKey(key,'keyup');pressed=false;},80);
  };
  const up=e=>{
    e.preventDefault();
    if(hold&&pressed)gameKey(key,'keyup');
    pressed=false;
  };
  btn.addEventListener('pointerdown',down);
  btn.addEventListener('pointerup',up);
  btn.addEventListener('pointercancel',up);
  btn.addEventListener('pointerleave',up);
}

function canvasPoint(canvas,e){
  const rect=canvas.getBoundingClientRect();
  return {
    x:(e.clientX-rect.left)*(canvas.width/rect.width),
    y:(e.clientY-rect.top)*(canvas.height/rect.height)
  };
}

// ===== REFLEX GRID =====
function launchReflex(wrap){
  let score=0,combo=0,time=30,hot=-1,running=false,timer=null,spawnTimer=null;
  const best=+(localStorage.getItem('nz-reflex-best')||0);
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='⚡ Reflex Grid';wrap.appendChild(titleEl);
  const bar=document.createElement('div');bar.className='gscore-bar';
  bar.innerHTML=`<div class="glass sbox" style="padding:10px 20px"><div class="sval" id="rxScore">0</div><div class="slbl">Score</div></div><div class="glass sbox" style="padding:10px 20px"><div class="sval" id="rxTime">30</div><div class="slbl">Secondes</div></div><div class="glass sbox" style="padding:10px 20px"><div class="sval" id="rxBest">${best}</div><div class="slbl">Record</div></div>`;
  wrap.appendChild(bar);
  const board=document.createElement('div');board.className='reflex-board glass';board.style.padding='14px';wrap.appendChild(board);
  const cells=Array.from({length:16},(_,i)=>{
    const cell=document.createElement('button');
    cell.type='button';
    cell.className='reflex-cell';
    cell.onclick=()=>hit(i);
    board.appendChild(cell);
    return cell;
  });
  const start=document.createElement('button');start.className='btn ac';start.innerHTML='▶ Jouer';start.onclick=startGame;wrap.appendChild(start);

  function startGame(){
    score=0;combo=0;time=30;running=true;start.innerHTML='↺ Restart';
    clearInterval(timer);clearTimeout(spawnTimer);
    document.getElementById('rxScore').textContent=0;
    document.getElementById('rxTime').textContent=30;
    nextHot();
    activeInterval=timer=setInterval(()=>{
      time--;
      document.getElementById('rxTime').textContent=time;
      if(time<=0)finish();
    },1000);
  }
  function nextHot(){
    cells.forEach(c=>c.classList.remove('hot'));
    hot=Math.floor(Math.random()*cells.length);
    cells[hot].classList.add('hot');
    clearTimeout(spawnTimer);
    activeTimeout=spawnTimer=setTimeout(()=>{combo=0;if(running)nextHot();},Math.max(470,1050-score*8));
  }
  function hit(i){
    if(!running)return;
    if(i===hot){
      combo++;
      score+=10+combo*2;
      document.getElementById('rxScore').textContent=score;
      nextHot();
    }else{
      combo=0;
      score=Math.max(0,score-5);
      document.getElementById('rxScore').textContent=score;
    }
  }
  function finish(){
    running=false;clearInterval(timer);clearTimeout(spawnTimer);activeInterval=null;activeTimeout=null;
    cells.forEach(c=>c.classList.remove('hot'));
    const old=+(localStorage.getItem('nz-reflex-best')||0);
    if(score>old){localStorage.setItem('nz-reflex-best',score);document.getElementById('rxBest').textContent=score;toast('Nouveau record: '+score+' ✓');}
    else toast('Score: '+score);
  }
  gameKeyHandler=()=>{};
}

// ===== SNAKE =====
function launchSnake(wrap){
  const CELL=18,COLS=26,ROWS=22;
  let snake,dir,food,score,best=+(localStorage.getItem('nz-sbest')||0),level,running,paused;
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='🐍 Snake';wrap.appendChild(titleEl);
  const bar=document.createElement('div');bar.className='gscore-bar';
  bar.innerHTML=`<div class="glass sbox" style="padding:10px 20px"><div class="sval" id="gS">0</div><div class="slbl">Score</div></div><div class="glass sbox" style="padding:10px 20px"><div class="sval" id="gB">${best}</div><div class="slbl">Record</div></div><div class="glass sbox" style="padding:10px 20px"><div class="sval" id="gL">1</div><div class="slbl">Niveau</div></div>`;
  wrap.appendChild(bar);
  const gameWrap=document.createElement('div');gameWrap.className='game-wrap glass';
  const canvas=document.createElement('canvas');canvas.id='snakeCanvas';canvas.width=COLS*CELL;canvas.height=ROWS*CELL;
  const overlay=document.createElement('div');overlay.className='game-overlay';overlay.id='gOverlay';
  overlay.innerHTML=`<div style="font-family:'Syne',sans-serif;font-size:1.8rem;font-weight:800" id="gMsg">Prêt ?</div><div style="font-size:.85rem;color:var(--text-dim)">Flèches / WASD · P = Pause</div><button class="btn ac" style="margin-top:8px;padding:12px 32px">▶ Jouer</button>`;
  overlay.querySelector('.btn').onclick=startSnake;
  gameWrap.appendChild(canvas);gameWrap.appendChild(overlay);wrap.appendChild(gameWrap);

  function startSnake(){
    snake=[{x:13,y:11},{x:12,y:11},{x:11,y:11}];dir={x:1,y:0};score=0;level=1;running=true;paused=false;
    document.getElementById('gS').innerText=0;document.getElementById('gL').innerText=1;
    document.getElementById('gOverlay').classList.add('hidden');
    placeFood();clearInterval(activeInterval);activeInterval=setInterval(tick,150);
  }
  function placeFood(){food={x:Math.floor(Math.random()*COLS),y:Math.floor(Math.random()*ROWS)};}
  function tick(){
    if(!running||paused)return;
    const head={x:(snake[0].x+dir.x+COLS)%COLS,y:(snake[0].y+dir.y+ROWS)%ROWS};
    if(snake.some(s=>s.x===head.x&&s.y===head.y)){
      running=false;clearInterval(activeInterval);activeInterval=null;
      const ov=document.getElementById('gOverlay');ov.classList.remove('hidden');
      document.getElementById('gMsg').innerText='Game Over';
      if(score>best){best=score;localStorage.setItem('nz-sbest',best);}
      return;
    }
    snake.unshift(head);
    if(head.x===food.x&&head.y===food.y){
      score+=10+level*5;document.getElementById('gS').innerText=score;
      if(score>best){best=score;document.getElementById('gB').innerText=best;}
      if(score%(50+level*30)===0){level++;document.getElementById('gL').innerText=level;clearInterval(activeInterval);activeInterval=setInterval(tick,Math.max(85,150-level*14));}
      placeFood();
    }else{snake.pop();}
    drawSnake();
  }
  function drawSnake(){
    const ctx=canvas.getContext('2d');
    const ac=getComputedStyle(document.body).getPropertyValue('--accent').trim()||'#4f96ff';
    ctx.clearRect(0,0,canvas.width,canvas.height);
    ctx.fillStyle='rgba(255,255,255,.02)';
    for(let x=0;x<COLS;x++)for(let y=0;y<ROWS;y++)if((x+y)%2===0)ctx.fillRect(x*CELL,y*CELL,CELL,CELL);
    ctx.shadowColor='#ff6b6b';ctx.shadowBlur=12;ctx.fillStyle='#ff6b6b';
    ctx.beginPath();ctx.arc(food.x*CELL+CELL/2,food.y*CELL+CELL/2,CELL/2-2,0,Math.PI*2);ctx.fill();ctx.shadowBlur=0;
    snake.forEach((s,i)=>{
      const alpha=1-i/snake.length*.5;ctx.globalAlpha=alpha;
      ctx.shadowColor=ac;ctx.shadowBlur=i===0?14:5;
      ctx.fillStyle=i===0?ac:`color-mix(in srgb,${ac} 70%,#000)`;
      const pad=i===0?1:2;
      ctx.beginPath();ctx.roundRect(s.x*CELL+pad,s.y*CELL+pad,CELL-pad*2,CELL-pad*2,4);ctx.fill();
    });
    ctx.globalAlpha=1;ctx.shadowBlur=0;
  }
  const map={ArrowUp:{x:0,y:-1},ArrowDown:{x:0,y:1},ArrowLeft:{x:-1,y:0},ArrowRight:{x:1,y:0},w:{x:0,y:-1},s:{x:0,y:1},a:{x:-1,y:0},d:{x:1,y:0}};
  gameKeyHandler=e=>{
    const nd=map[e.key];
    if(nd&&running&&!(nd.x===-dir.x&&nd.y===-dir.y)){dir=nd;e.preventDefault();}
    if(e.key==='p'||e.key==='P'){paused=!paused;}
  };
  document.addEventListener('keydown',gameKeyHandler);
  addGameControls(wrap,{pause:true});
}

// ===== TETRIS =====
function launchTetris(wrap){
  const W=10,H=20,SZ=24;
  const PIECES=[
    {s:[[1,1,1,1]],c:'#22d3ee'},
    {s:[[1,0],[1,0],[1,1]],c:'#f97316'},
    {s:[[0,1],[0,1],[1,1]],c:'#3b82f6'},
    {s:[[1,1],[1,1]],c:'#eab308'},
    {s:[[0,1,1],[1,1,0]],c:'#22c55e'},
    {s:[[1,1,1],[0,1,0]],c:'#a855f7'},
    {s:[[1,1,0],[0,1,1]],c:'#ef4444'},
  ];
  let board=Array.from({length:H},()=>Array(W).fill(0));
  let cur,curX,curY,nextPiece,score=0,lines=0,level=1,running=false,paused=false;
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='🟦 Tetris';wrap.appendChild(titleEl);
  const tetWrap=document.createElement('div');tetWrap.className='tetris-wrap';
  const canvas=document.createElement('canvas');canvas.id='tetrisCanvas';canvas.width=W*SZ;canvas.height=H*SZ;canvas.style.border='1px solid rgba(255,255,255,0.1)';
  const side=document.createElement('div');side.className='tetris-side';
  side.innerHTML=`<div class="glass tet-panel"><div class="tet-label">Score</div><div class="tet-val" id="tScore">0</div></div><div class="glass tet-panel"><div class="tet-label">Lignes</div><div class="tet-val" id="tLines">0</div></div><div class="glass tet-panel"><div class="tet-label">Niveau</div><div class="tet-val" id="tLevel">1</div></div><div class="glass tet-panel"><div class="tet-label">Suivant</div><canvas id="nextCanvas" width="80" height="80"></canvas></div><button class="btn ac" id="tetStart" style="margin-top:4px">▶ Jouer</button>`;
  tetWrap.appendChild(canvas);tetWrap.appendChild(side);wrap.appendChild(tetWrap);
  side.querySelector('#tetStart').onclick=startTetris;

  function randPiece(){return JSON.parse(JSON.stringify(PIECES[Math.floor(Math.random()*PIECES.length)]));}
  function startTetris(){
    board=Array.from({length:H},()=>Array(W).fill(0));score=0;lines=0;level=1;running=true;paused=false;
    ['tScore','tLines','tLevel'].forEach(id=>document.getElementById(id).innerText=id==='tLevel'?1:0);
    nextPiece=randPiece();spawnPiece();
    clearInterval(activeInterval);activeInterval=setInterval(drop,520);
    side.querySelector('#tetStart').innerText='↺ Restart';
  }
  function spawnPiece(){
    cur=nextPiece;nextPiece=randPiece();
    curX=Math.floor((W-cur.s[0].length)/2);curY=0;
    if(!valid(cur.s,curX,curY)){running=false;clearInterval(activeInterval);activeInterval=null;toast('Game Over · '+score+' pts');}
    drawNext();
  }
  function drop(){if(!running||paused)return;if(valid(cur.s,curX,curY+1)){curY++;}else{lock();clearLines();spawnPiece();}draw();}
  function valid(s,x,y){return s.every((row,r)=>row.every((v,c)=>!v||((y+r)>=0&&(y+r)<H&&(x+c)>=0&&(x+c)<W&&!board[y+r][x+c])));}
  function lock(){cur.s.forEach((row,r)=>row.forEach((v,c)=>{if(v)board[curY+r][curX+c]=cur.c;}));}
  function clearLines(){
    let n=0;
    for(let r=H-1;r>=0;r--){if(board[r].every(v=>v)){board.splice(r,1);board.unshift(Array(W).fill(0));n++;r++;}}
    if(n){score+=[0,100,300,500,800][n]*level;lines+=n;level=Math.floor(lines/10)+1;
    ['tScore','tLines','tLevel'].forEach(id=>{document.getElementById(id).innerText={tScore:score,tLines:lines,tLevel:level}[id];});
    clearInterval(activeInterval);activeInterval=setInterval(drop,Math.max(130,520-level*32));}
  }
  function draw(){
    const ctx=canvas.getContext('2d');ctx.fillStyle='rgba(0,0,0,0.4)';ctx.fillRect(0,0,canvas.width,canvas.height);
    // board
    board.forEach((row,r)=>row.forEach((v,c)=>{if(v){ctx.fillStyle=v;ctx.shadowColor=v;ctx.shadowBlur=6;ctx.fillRect(c*SZ+1,r*SZ+1,SZ-2,SZ-2);ctx.shadowBlur=0;}}));
    // ghost
    if(cur){let ghostY=curY;while(valid(cur.s,curX,ghostY+1))ghostY++;
    cur.s.forEach((row,r)=>row.forEach((v,c)=>{if(v&&ghostY!==curY){ctx.fillStyle='rgba(255,255,255,0.08)';ctx.fillRect((curX+c)*SZ+1,(ghostY+r)*SZ+1,SZ-2,SZ-2);}}));}
    // current piece
    if(cur)cur.s.forEach((row,r)=>row.forEach((v,c)=>{if(v){ctx.fillStyle=cur.c;ctx.shadowColor=cur.c;ctx.shadowBlur=8;ctx.fillRect((curX+c)*SZ+1,(curY+r)*SZ+1,SZ-2,SZ-2);ctx.shadowBlur=0;}}));
    // grid
    ctx.strokeStyle='rgba(255,255,255,0.03)';ctx.lineWidth=1;
    for(let r=0;r<H;r++){ctx.beginPath();ctx.moveTo(0,r*SZ);ctx.lineTo(W*SZ,r*SZ);ctx.stroke();}
    for(let c=0;c<W;c++){ctx.beginPath();ctx.moveTo(c*SZ,0);ctx.lineTo(c*SZ,H*SZ);ctx.stroke();}
  }
  function drawNext(){
    const nc=document.getElementById('nextCanvas');if(!nc)return;
    const ctx=nc.getContext('2d');ctx.clearRect(0,0,80,80);
    if(!nextPiece)return;
    const s=nextPiece.s,ns=20;
    const ox=(4-s[0].length)/2*ns,oy=(4-s.length)/2*ns;
    s.forEach((row,r)=>row.forEach((v,c)=>{if(v){ctx.fillStyle=nextPiece.c;ctx.shadowColor=nextPiece.c;ctx.shadowBlur=6;ctx.fillRect(ox+c*ns+1,oy+r*ns+1,ns-2,ns-2);ctx.shadowBlur=0;}}));
  }
  draw();
  gameKeyHandler=e=>{
    if(!running)return;
    if(e.key==='p'||e.key==='P'){paused=!paused;toast(paused?'⏸ Pause':'▶ Reprise');return;}
    if(paused)return;
    if(e.key==='ArrowLeft'&&valid(cur.s,curX-1,curY)){curX--;draw();}
    else if(e.key==='ArrowRight'&&valid(cur.s,curX+1,curY)){curX++;draw();}
    else if(e.key==='ArrowDown'){drop();}
    else if(e.key==='ArrowUp'){
      const rot=cur.s[0].map((_,i)=>cur.s.map(r=>r[i]).reverse());
      if(valid(rot,curX,curY)){cur.s=rot;draw();}
    }
    else if(e.key===' '){
      while(valid(cur.s,curX,curY+1))curY++;lock();clearLines();spawnPiece();draw();
    }
  };
  document.addEventListener('keydown',gameKeyHandler);
  addGameControls(wrap,{actions:[{label:'Drop',key:' '},{label:'Tourner',key:'ArrowUp'}],pause:true});
}

