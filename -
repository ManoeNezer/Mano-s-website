function selSwatch(el){document.querySelectorAll('.psw').forEach(s=>s.classList.remove('selected'));el.classList.add('selected');}
function setPtool(t){
  ptool=t;
  ['pen','fill','erase','line','rect','circle','picker'].forEach(x=>{const el=document.getElementById('ptool-'+x);if(el)el.classList.toggle('active',x===t);});
}
function fitPaletteCanvas(force){
  const c=document.getElementById('palCanvas');
  const rect=c.getBoundingClientRect();
  const w=Math.max(320,Math.round(rect.width||600));
  const h=Math.max(220,Math.round(rect.height||400));
  if(!force&&c.width===w&&c.height===h)return;
  const old=document.createElement('canvas');
  if(c.width&&c.height){
    old.width=c.width;old.height=c.height;
    old.getContext('2d').drawImage(c,0,0);
  }
  c.width=w;c.height=h;
  const ctx=c.getContext('2d');
  ctx.fillStyle='#fff';ctx.fillRect(0,0,w,h);
  if(old.width)ctx.drawImage(old,0,0,w,h);
}
function canvasPoint(c,e){
  const r=c.getBoundingClientRect();
  return {x:(e.clientX-r.left)*c.width/r.width,y:(e.clientY-r.top)*c.height/r.height};
}
function scaledBrush(c){return psize*(c.width/(c.getBoundingClientRect().width||c.width));}
function saveCanvasState(){
  const c=document.getElementById('palCanvas');
  if(!c||!c.width)return;
  pHistory.push(c.toDataURL('image/png'));
  if(pHistory.length>30)pHistory.shift();
  pRedoStack=[];
}
function restoreCanvasState(url,cb){
  const c=document.getElementById('palCanvas'),ctx=c.getContext('2d'),img=new Image();
  img.onload=()=>{ctx.clearRect(0,0,c.width,c.height);ctx.drawImage(img,0,0,c.width,c.height);if(cb)cb();};
  img.src=url;
}
function undoCanvas(){
  if(pHistory.length<=1){toast('Rien à annuler');return;}
  const c=document.getElementById('palCanvas');
  pRedoStack.push(c.toDataURL('image/png'));
  const prev=pHistory.pop();
  restoreCanvasState(prev);
}
function redoCanvas(){
  if(!pRedoStack.length){toast('Rien à rétablir');return;}
  const c=document.getElementById('palCanvas');
  const next=pRedoStack.pop();
  pHistory.push(c.toDataURL('image/png'));
  restoreCanvasState(next);
}
function palettePointerDown(e){
  const c=document.getElementById('palCanvas');
  c.setPointerCapture?.(e.pointerId);
  const p=canvasPoint(c,e);
  pdown=true;pstart=p;
  if(ptool==='picker'){pickColor(c,p.x,p.y);pdown=false;return;}
  if(ptool==='fill'){saveCanvasState();floodFill(c,p.x,p.y,pcolor);pdown=false;return;}
  saveCanvasState();
  const ctx=c.getContext('2d');
  if(ptool==='pen'||ptool==='erase'){
    ctx.beginPath();ctx.moveTo(p.x,p.y);
  }else{
    psnap=ctx.getImageData(0,0,c.width,c.height);
  }
  e.preventDefault();
}
function palettePointerMove(e){
  if(!pdown)return;
  const c=document.getElementById('palCanvas');
  const p=canvasPoint(c,e);
  draw(c,p.x,p.y);
  e.preventDefault();
}
function palettePointerUp(e){
  if(!pdown)return;
  const c=document.getElementById('palCanvas');
  const p=canvasPoint(c,e);
  if(ptool==='line'||ptool==='rect'||ptool==='circle')drawShape(c,p.x,p.y);
  pdown=false;pstart=null;psnap=null;
  e.preventDefault();
}
function draw(c,x,y){
  const ctx=c.getContext('2d');
  if(ptool==='pen'||ptool==='erase'){
    ctx.globalAlpha=ptool==='erase'?1:popacityV;
    ctx.strokeStyle=ptool==='erase'?'#ffffff':pcolor;
    ctx.lineWidth=scaledBrush(c);ctx.lineCap='round';ctx.lineJoin='round';
    ctx.lineTo(x,y);ctx.stroke();ctx.beginPath();ctx.moveTo(x,y);ctx.globalAlpha=1;
  }else if(ptool==='line'||ptool==='rect'||ptool==='circle'){
    if(!psnap)return;
    ctx.putImageData(psnap,0,0);drawShapePreview(ctx,x,y);
  }
}
function drawShapePreview(ctx,x,y){
  const c=ctx.canvas;
  ctx.globalAlpha=popacityV;ctx.strokeStyle=pcolor;ctx.lineWidth=scaledBrush(c);ctx.lineCap='round';ctx.lineJoin='round';ctx.beginPath();
  if(ptool==='line'){ctx.moveTo(pstart.x,pstart.y);ctx.lineTo(x,y);}
  else if(ptool==='rect'){ctx.rect(pstart.x,pstart.y,x-pstart.x,y-pstart.y);}
  else if(ptool==='circle'){const r=Math.sqrt((x-pstart.x)**2+(y-pstart.y)**2);ctx.arc(pstart.x,pstart.y,r,0,Math.PI*2);}
  ctx.stroke();ctx.globalAlpha=1;
}
function drawShape(c,x,y){const ctx=c.getContext('2d');if(psnap)ctx.putImageData(psnap,0,0);drawShapePreview(ctx,x,y);}
function pickColor(c,x,y){
  const ctx=c.getContext('2d'),d=ctx.getImageData(Math.floor(x),Math.floor(y),1,1).data;
  const hex='#'+[d[0],d[1],d[2]].map(v=>v.toString(16).padStart(2,'0')).join('');
  pcolor=hex;document.getElementById('pcolor').value=hex;updatePalInfo(hex);setPtool('pen');toast('Couleur: '+hex.toUpperCase());
}
function floodFill(c,sx,sy,fillColor){
  sx=Math.floor(sx);sy=Math.floor(sy);
  const ctx=c.getContext('2d');const W=c.width,H=c.height;
  const img=ctx.getImageData(0,0,W,H);const d=img.data;
  const idx=(x,y)=>(y*W+x)*4;
  const target=d.slice(idx(sx,sy),idx(sx,sy)+4);
  const fc=[parseInt(fillColor.slice(1,3),16),parseInt(fillColor.slice(3,5),16),parseInt(fillColor.slice(5,7),16),255];
  if(target.every((v,i)=>Math.abs(v-fc[i])<3))return;
  const tolerance=26;
  const match=i=>target.every((v,j)=>Math.abs(d[i+j]-v)<=tolerance);
  const stack=[[sx,sy]];
  while(stack.length){const [x,y]=stack.pop();if(x<0||y<0||x>=W||y>=H)continue;const i=idx(x,y);if(!match(i))continue;fc.forEach((v,j)=>d[i+j]=v);stack.push([x+1,y],[x-1,y],[x,y+1],[x,y-1]);}
  ctx.putImageData(img,0,0);
}
