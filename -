function launchPong(wrap){
  const W=600,H=400;
  let p1y=H/2-40,p2y=H/2-40,bx=W/2,by=H/2,bdx=4,bdy=3,p1s=0,p2s=0,running=false,paused=false;
  const PH=80,PW=12,BR=8;
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='🏓 Pong';wrap.appendChild(titleEl);
  const canvas=document.createElement('canvas');canvas.id='pongCanvas';canvas.width=W;canvas.height=H;wrap.appendChild(canvas);
  const ctx=canvas.getContext('2d');
  const hint=document.createElement('div');hint.style.cssText='font-size:.75rem;color:var(--text-dim);margin-top:8px;';hint.innerText='W/S = Joueur 1 · Flèches ↑↓ = Joueur 2 · P = Pause';wrap.appendChild(hint);
  const keys={};
  gameKeyHandler=e=>{keys[e.key]=e.type==='keydown';if(e.key==='p'||e.key==='P'){paused=!paused;toast(paused?'⏸ Pause':'▶ Reprise');}e.preventDefault();};
  document.addEventListener('keydown',gameKeyHandler);
  gameKeyupHandler=e=>{keys[e.key]=false;};
  document.addEventListener('keyup',gameKeyupHandler);

  function drawPong(){
    const ac=getComputedStyle(document.body).getPropertyValue('--accent').trim()||'#4f96ff';
    ctx.fillStyle='rgba(0,0,0,0.5)';ctx.fillRect(0,0,W,H);
    // center line
    ctx.setLineDash([8,8]);ctx.strokeStyle='rgba(255,255,255,0.12)';ctx.lineWidth=2;ctx.beginPath();ctx.moveTo(W/2,0);ctx.lineTo(W/2,H);ctx.stroke();ctx.setLineDash([]);
    // paddles
    ctx.fillStyle=ac;ctx.shadowColor=ac;ctx.shadowBlur=12;
    ctx.beginPath();ctx.roundRect(10,p1y,PW,PH,4);ctx.fill();
    ctx.beginPath();ctx.roundRect(W-PW-10,p2y,PW,PH,4);ctx.fill();
    ctx.shadowBlur=0;
    // ball
    ctx.beginPath();ctx.arc(bx,by,BR,0,Math.PI*2);ctx.fillStyle='white';ctx.shadowColor='white';ctx.shadowBlur=16;ctx.fill();ctx.shadowBlur=0;
    // scores
    ctx.fillStyle='rgba(255,255,255,0.8)';ctx.font='bold 36px Space Mono,monospace';ctx.textAlign='center';
    ctx.fillText(p1s,W/4,50);ctx.fillText(p2s,3*W/4,50);
  }
  function updatePong(){
    if(!running||paused)return;
    if(keys['w']||keys['W'])p1y=Math.max(0,p1y-6);
    if(keys['s']||keys['S'])p1y=Math.min(H-PH,p1y+6);
    if(keys['ArrowUp'])p2y=Math.max(0,p2y-6);
    if(keys['ArrowDown'])p2y=Math.min(H-PH,p2y+6);
    // simple AI for P2 when no key
    if(!keys['ArrowUp']&&!keys['ArrowDown']){const mid=p2y+PH/2;if(mid<by-4)p2y+=3;else if(mid>by+4)p2y-=3;}
    bx+=bdx;by+=bdy;
    if(by<=BR||by>=H-BR)bdy=-bdy;
    if(bx<=PW+10+BR&&by>=p1y&&by<=p1y+PH){bdx=Math.abs(bdx);bdy+=(by-(p1y+PH/2))/PH*4;}
    if(bx>=W-PW-10-BR&&by>=p2y&&by<=p2y+PH){bdx=-Math.abs(bdx);bdy+=(by-(p2y+PH/2))/PH*4;}
    bdy=Math.max(-5.5,Math.min(5.5,bdy));
    if(bx<0){p2s++;resetBall();}if(bx>W){p1s++;resetBall();}
  }
  function resetBall(){bx=W/2;by=H/2;bdx=(Math.random()>.5?1:-1)*4;bdy=(Math.random()-.5)*4;}
  function loop(){updatePong();drawPong();}
  running=true;startRafLoop(loop,60);
  addGameControls(wrap,{actions:[{label:'P1 ↑',key:'w',hold:true},{label:'P1 ↓',key:'s',hold:true}],pause:true});
}

