const SWATCHES=['#4f96ff','#c084fc','#f472b6','#fb923c','#facc15','#4ade80','#22d3ee','#f87171','#ffffff','#000000','#1e293b','#7c3aed','#0891b2','#15803d','#b45309','#be123c','#374151','#6b7280','#e2e8f0','#0ea5e9'];
function initPalette(){
