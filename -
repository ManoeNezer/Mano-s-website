let curView='home';
function nav(id,el){
  if(id===curView)return;
  const old=document.getElementById(curView);
  if(old){
    old.classList.add('out');
    old.classList.remove('in');
    setTimeout(()=>{old.style.display='none';old.classList.remove('out');},520);
  }
  curView=id;
  const nw=document.getElementById(id);
  nw.style.display='block';
  requestAnimationFrame(()=>requestAnimationFrame(()=>nw.classList.add('in')));
  document.querySelectorAll('.sicon').forEach(i=>i.classList.remove('active'));
  if(el&&el.classList)el.classList.add('active');
  if(id==='palette')initPalette();
  if(id==='math')setTimeout(doPlot,200);
  if(id==='arcade')buildGameHub();
  if(id==='focus')focusInit();
  if(id==='converter')converterInit();
}
