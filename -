}

function converterCopy(){
  const res=converterCalc();
  const text=`${res.formula} ${res.result}`;
  if(navigator.clipboard){
    navigator.clipboard.writeText(text).then(()=>toast('Conversion copiée ✓')).catch(()=>converterFallbackCopy(text));
  }else{
    converterFallbackCopy(text);
  }
}

function converterFallbackCopy(text){
  const ta=document.createElement('textarea');
  ta.value=text;
  document.body.appendChild(ta);
  ta.select();
  document.execCommand('copy');
  ta.remove();
  toast('Conversion copiée ✓');
}

function converterReset(){
  document.getElementById('convCategory').value='length';
  document.getElementById('convValue').value=1;
  converterRenderUnits();
  converterCalc();
}

