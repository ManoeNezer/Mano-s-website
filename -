  c.addEventListener('pointercancel',palettePointerUp);
  window.addEventListener('resize',()=>fitPaletteCanvas(false));
  document.getElementById('pcolor').oninput=e=>{pcolor=e.target.value;updatePalInfo(pcolor);};
