// ============ SETTINGS / THEMES / AUDIO ============
function openTheme(){document.getElementById('themeMenu').classList.add('open');}
function closeTheme(){document.getElementById('themeMenu').classList.remove('open');}
const TNAMES={
  noir:'Noir Pulse',
  graphite:'Graphite Blue',
  halo:'Halo Light',
  frost:'Frost Mint',
  sunrise:'Sunrise Soft'
};
const THEME_CLASSES=Object.keys(TNAMES).map(t=>'t-'+t);
const SETTINGS_VERSION=3;
const SETTINGS_DEFAULT={
  settingsVersion:SETTINGS_VERSION,
  glass:38,
  liquid:88,
  refraction:92,
  chroma:100,
  edge:92,
  contrast:108,
  bgDetail:92,
  grain:26,
  scale:100,
  motion:true,
  audio:false,
  volume:38,
  uiSound:true,
  ambient:true
};
let siteSettings={...SETTINGS_DEFAULT};
const siteAudio={ctx:null,master:null,ambientGain:null,uiGain:null,ambientNodes:[],started:false};

function setT(t){
  if(!TNAMES[t])t='noir';
  document.body.classList.remove(...THEME_CLASSES);
  document.body.classList.add('t-'+t);
  localStorage.setItem('nz-theme',t);
  syncThemeButtons(t);
  closeTheme();
  toast('Thème : '+TNAMES[t]);
  uiTick('theme');
}

function syncThemeButtons(theme){
  document.querySelectorAll('.tbtn[data-theme]').forEach(btn=>{
    btn.classList.toggle('active',btn.dataset.theme===theme);
  });
}

function loadSettings(){
  try{
    const saved=JSON.parse(localStorage.getItem('nz-settings')||'{}');
    siteSettings=saved.settingsVersion===SETTINGS_VERSION?{...SETTINGS_DEFAULT,...saved}:{...SETTINGS_DEFAULT};
  }catch{
    siteSettings={...SETTINGS_DEFAULT};
  }
  const savedTheme=localStorage.getItem('nz-theme');
  const theme=TNAMES[savedTheme]?savedTheme:'noir';
  document.body.classList.remove(...THEME_CLASSES);
  document.body.classList.add('t-'+theme);
  syncThemeButtons(theme);
  applySettings(false);
  localStorage.setItem('nz-settings',JSON.stringify(siteSettings));
}

function resetSiteSettings(){
  siteSettings={...SETTINGS_DEFAULT};
  document.body.classList.remove(...THEME_CLASSES);
  document.body.classList.add('t-noir');
  localStorage.setItem('nz-theme','noir');
  syncThemeButtons('noir');
  applySettings();
  toast('Paramètres réinitialisés');
  uiTick('glass');
}

function updateSetting(key,value){
  if(['glass','liquid','refraction','chroma','edge','contrast','bgDetail','grain','scale','volume'].includes(key))value=Number(value);
  siteSettings[key]=value;
  applySettings();
  uiTick(['refraction','chroma','edge','glass'].includes(key)?'glass':key);
}

function applySettings(save=true){
  const root=document.documentElement;
  const glass=Math.max(20,Math.min(68,Number(siteSettings.glass)||44));
  const liquid=Math.max(0,Math.min(100,Number(siteSettings.liquid)||72));
  const refraction=Math.max(0,Math.min(100,Number(siteSettings.refraction)||62));
  const chroma=Math.max(0,Math.min(100,Number(siteSettings.chroma)||72));
  const edge=Math.max(20,Math.min(100,Number(siteSettings.edge)||78));
  const contrast=Math.max(88,Math.min(124,Number(siteSettings.contrast)||108));
  const bgDetail=Math.max(20,Math.min(100,Number(siteSettings.bgDetail)||82));
  const grain=Math.max(0,Math.min(100,Number(siteSettings.grain)||18));
  const scale=Math.max(92,Math.min(110,Number(siteSettings.scale)||100));
  const volume=Math.max(0,Math.min(100,Number(siteSettings.volume)||38));
  root.style.setProperty('--glass-blur',glass+'px');
  root.style.setProperty('--glass-small-blur',Math.round(glass*.55)+'px');
  const alpha=0.18+(glass-20)/48*.23;
  root.style.setProperty('--glass-alpha',alpha.toFixed(3));
  root.style.setProperty('--glass-fill-1',Math.min(.64,alpha+.18).toFixed(3));
  root.style.setProperty('--glass-fill-2',Math.max(.06,alpha*.30).toFixed(3));
  root.style.setProperty('--glass-fill-3',Math.max(.10,alpha*.58).toFixed(3));
  root.style.setProperty('--liquid-opacity',(liquid/100).toFixed(2));
  const refractScale=Math.round(4+refraction/100*58);
  root.style.setProperty('--refract-scale',refractScale);
  const refractOpacity=Math.min(.88,.26+refraction/100*.50+liquid/100*.12);
  root.style.setProperty('--refract-opacity',refractOpacity.toFixed(2));
  const sx=(4+refraction/100*20).toFixed(1);
  const sy=(3+refraction/100*16).toFixed(1);
  root.style.setProperty('--refract-shift-x',sx+'px');
  root.style.setProperty('--refract-shift-x-neg','-'+sx+'px');
  root.style.setProperty('--refract-shift-y','-'+sy+'px');
  root.style.setProperty('--refract-shift-y-neg',sy+'px');
  root.style.setProperty('--chroma-strength',(chroma/100).toFixed(2));
  root.style.setProperty('--chroma-x',(chroma/100*4.8).toFixed(1)+'px');
  root.style.setProperty('--chroma-x-neg','-'+(chroma/100*4.8).toFixed(1)+'px');
  root.style.setProperty('--chroma-blur',(6+chroma/100*18).toFixed(1)+'px');
  root.style.setProperty('--chroma-a1',(chroma/100*.62).toFixed(2));
  root.style.setProperty('--chroma-a2',(chroma/100*.68).toFixed(2));
  root.style.setProperty('--chroma-a3',(chroma/100*.52).toFixed(2));
  root.style.setProperty('--edge-strength',(edge/100).toFixed(2));
  root.style.setProperty('--edge-y',(edge/100*3.4).toFixed(1)+'px');
  root.style.setProperty('--edge-y-neg','-'+(edge/100*3.4).toFixed(1)+'px');
  root.style.setProperty('--edge-blur',(5+edge/100*17).toFixed(1)+'px');
  root.style.setProperty('--edge-a',(.18+edge/100*.72).toFixed(2));
  root.style.setProperty('--edge-opacity',(.30+edge/100*.62).toFixed(2));
  root.style.setProperty('--bg-detail',(bgDetail/100).toFixed(2));
  root.style.setProperty('--bg-detail-soft',(bgDetail/100*.78).toFixed(2));
  root.style.setProperty('--bg-node-opacity',Math.min(.92,bgDetail/100*.48+grain/100*.34).toFixed(2));
  root.style.setProperty('--bg-caustic-opacity',(bgDetail/100*(.28+liquid/100*.48)).toFixed(2));
  root.style.setProperty('--caustic-strength',(liquid/100).toFixed(2));
  root.style.setProperty('--grain-strength',(grain/100).toFixed(2));
  root.style.setProperty('--glass-contrast',(contrast/100).toFixed(2));
  root.style.setProperty('--scene-flow',siteSettings.motion?'18s':'999s');
  root.style.setProperty('--caustic-flow',siteSettings.motion?'21s':'999s');
  root.style.setProperty('--base-font-size',(16*scale/100).toFixed(2)+'px');
  const lgDisplace=document.getElementById('lgDisplace');
  const lgLensDisplace=document.getElementById('lgLensDisplace');
  const lgNoise=document.getElementById('lgNoise');
  if(lgDisplace)lgDisplace.setAttribute('scale',String(refractScale));
  if(lgLensDisplace)lgLensDisplace.setAttribute('scale',String(Math.round(3+refraction/100*13)));
  if(lgNoise)lgNoise.setAttribute('baseFrequency',`${(0.0028+refraction/100*.0048).toFixed(4)} ${(0.0022+refraction/100*.0038).toFixed(4)}`);
  document.body.classList.toggle('motion-off',!siteSettings.motion);
  document.body.classList.toggle('audio-enabled',!!siteSettings.audio);
  syncSettingsControls();
  updateAudioLevels(volume/100);
  if(save)localStorage.setItem('nz-settings',JSON.stringify(siteSettings));
}

function syncSettingsControls(){
  const map={
    setGlass:'glass',
    setLiquid:'liquid',
    setRefraction:'refraction',
    setChroma:'chroma',
    setEdge:'edge',
    setContrast:'contrast',
    setBgDetail:'bgDetail',
    setGrain:'grain',
    setScale:'scale',
    setVolume:'volume'
  };
  Object.entries(map).forEach(([id,key])=>{
    const el=document.getElementById(id);
    if(el&&String(el.value)!==String(siteSettings[key]))el.value=siteSettings[key];
  });
  const checks={setMotion:'motion',setUiSound:'uiSound',setAmbient:'ambient'};
  Object.entries(checks).forEach(([id,key])=>{
    const el=document.getElementById(id);
    if(el)el.checked=!!siteSettings[key];
  });
  const audioBtn=document.getElementById('audioToggle');
  if(audioBtn){
    audioBtn.innerHTML=siteSettings.audio?'<i data-lucide="volume-2"></i><span>Audio activé</span>':'<i data-lucide="volume-x"></i><span>Activer l&rsquo;audio</span>';
    lucide.createIcons();
  }
  const quick=document.getElementById('audioQuickBtn');
  if(quick){
    quick.innerHTML=siteSettings.audio?'<i data-lucide="volume-2"></i>':'<i data-lucide="volume-x"></i>';
    quick.title=siteSettings.audio?'Couper l’audio':'Activer l’audio';
    lucide.createIcons();
  }
}

function ensureAudio(){
  if(siteAudio.ctx)return siteAudio.ctx;
  const AudioCtx=window.AudioContext||window.webkitAudioContext;
  if(!AudioCtx)return null;
  const ctx=new AudioCtx();
  const master=ctx.createGain();
  const ambientGain=ctx.createGain();
  const uiGain=ctx.createGain();
  master.connect(ctx.destination);
  ambientGain.connect(master);
  uiGain.connect(master);
  ambientGain.gain.value=0;
  uiGain.gain.value=.22;
  siteAudio.ctx=ctx;
  siteAudio.master=master;
  siteAudio.ambientGain=ambientGain;
  siteAudio.uiGain=uiGain;
  createAmbientLayer(ctx);
  updateAudioLevels((Number(siteSettings.volume)||38)/100);
  return ctx;
}

function createAmbientLayer(ctx){
  const tones=[
    {freq:96,type:'sine',gain:.19},
    {freq:144,type:'triangle',gain:.10},
    {freq:231,type:'sine',gain:.055}
  ];
  tones.forEach((tone,i)=>{
    const osc=ctx.createOscillator();
    const gain=ctx.createGain();
    const pan=ctx.createStereoPanner?ctx.createStereoPanner():null;
    osc.type=tone.type;
    osc.frequency.value=tone.freq;
    gain.gain.value=tone.gain;
    osc.connect(gain);
    if(pan){
      pan.pan.value=i===0?-.35:i===1?.28:0;
      gain.connect(pan);
      pan.connect(siteAudio.ambientGain);
      siteAudio.ambientNodes.push({osc,gain,pan});
    }else{
      gain.connect(siteAudio.ambientGain);
      siteAudio.ambientNodes.push({osc,gain});
    }
    osc.start();
  });
  const lfo=ctx.createOscillator();
  const lfoGain=ctx.createGain();
  lfo.frequency.value=.045;
  lfoGain.gain.value=.025;
  lfo.connect(lfoGain);
  lfoGain.connect(siteAudio.ambientNodes[0].gain.gain);
  lfo.start();
  siteAudio.ambientNodes.push({osc:lfo,gain:lfoGain});
}

async function toggleSiteAudio(){
  siteSettings.audio=!siteSettings.audio;
  if(siteSettings.audio){
    const ctx=ensureAudio();
    if(ctx&&ctx.state!=='running')await ctx.resume();
    siteAudio.started=true;
  }
  applySettings();
  toast(siteSettings.audio?'Audio global activé':'Audio coupé');
  uiTick('toggle');
}

function updateAudioLevels(vol){
  if(!siteAudio.master)return;
  const t=siteAudio.ctx.currentTime;
  siteAudio.master.gain.setTargetAtTime(siteSettings.audio?vol*.72:0,t,.05);
  siteAudio.ambientGain.gain.setTargetAtTime(siteSettings.audio&&siteSettings.ambient?vol*.28:0,t,.16);
  siteAudio.uiGain.gain.setTargetAtTime(siteSettings.audio&&siteSettings.uiSound?Math.max(.04,vol*.36):0,t,.03);
}

function uiTick(kind='tap'){
  if(!siteSettings.audio||!siteSettings.uiSound)return;
  const ctx=ensureAudio();
  if(!ctx||ctx.state!=='running')return;
  const now=ctx.currentTime;
  const osc=ctx.createOscillator();
  const gain=ctx.createGain();
  const filter=ctx.createBiquadFilter();
  filter.type='highpass';
  filter.frequency.value=360;
  const freqs={tap:440,theme:660,toggle:520,nav:380,glass:590};
  osc.type='sine';
  osc.frequency.setValueAtTime(freqs[kind]||freqs.tap,now);
  osc.frequency.exponentialRampToValueAtTime((freqs[kind]||freqs.tap)*1.55,now+.07);
  gain.gain.setValueAtTime(0,now);
  gain.gain.linearRampToValueAtTime(.12,now+.012);
  gain.gain.exponentialRampToValueAtTime(.001,now+.18);
  osc.connect(filter);
  filter.connect(gain);
  gain.connect(siteAudio.uiGain);
  osc.start(now);
  osc.stop(now+.2);
}

(function(){
  loadSettings();
  document.addEventListener('pointerdown',e=>{
    if(siteSettings.audio){
      const ctx=ensureAudio();
      if(ctx&&ctx.state!=='running')ctx.resume();
    }
    const hit=e.target.closest('button,.btn,.card,.sicon,.bnav-item,.mobile-more-item,.game-card,.tbtn');
    if(hit)uiTick(hit.classList.contains('card')||hit.classList.contains('sicon')?'nav':'tap');
  },{passive:true});
})();

