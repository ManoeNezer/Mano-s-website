// ============ FOCUS BOARD ============
const focusDurations={focus:25*60,short:5*60,long:15*60};
const focusLabels={focus:'Focus',short:'Pause courte',long:'Pause longue'};
let focusState={mode:'focus',left:focusDurations.focus,total:focusDurations.focus,running:false,tasks:[],notes:'',minutes:0};
let focusInterval=null;

function focusInit(){
  if(focusState._init)return;
  focusState._init=true;
  try{
    const saved=JSON.parse(localStorage.getItem('focus-board')||'{}');
    focusState={...focusState,...saved,running:false,left:saved.left||focusDurations[saved.mode||'focus'],total:saved.total||focusDurations[saved.mode||'focus']};
  }catch{}
  const notes=document.getElementById('focusNotes');
  if(notes)notes.value=focusState.notes||'';
  focusRender();
}

function focusSave(){
  const notes=document.getElementById('focusNotes');
  if(notes)focusState.notes=notes.value;
  const save={...focusState,running:false,_init:true};
  localStorage.setItem('focus-board',JSON.stringify(save));
}

function focusFormat(sec){
  const m=Math.floor(sec/60).toString().padStart(2,'0');
  const s=(sec%60).toString().padStart(2,'0');
  return `${m}:${s}`;
}

function focusRender(){
  const time=document.getElementById('focusTime');
  const mode=document.getElementById('focusMode');
  const ring=document.getElementById('focusRing');
  const btn=document.getElementById('focusStartBtn');
  const list=document.getElementById('focusTasks');
  const stats=document.getElementById('focusStats');
  if(!time||!mode||!ring||!btn||!list||!stats)return;
  time.textContent=focusFormat(focusState.left);
  mode.textContent=focusLabels[focusState.mode];
  const done=focusState.total?((focusState.total-focusState.left)/focusState.total*100):0;
  ring.style.setProperty('--focus-progress',Math.max(0,Math.min(100,done))+'%');
  btn.innerHTML=focusState.running?'<i data-lucide="pause"></i><span>Pause</span>':'<i data-lucide="play"></i><span>Démarrer</span>';
  list.innerHTML='';
  if(!focusState.tasks.length){
    const empty=document.createElement('div');
    empty.className='task-meta';
    empty.style.padding='12px';
    empty.textContent='Ajoute une tâche, lance le timer, avance proprement.';
    list.appendChild(empty);
  }
  focusState.tasks.forEach(task=>{
    const row=document.createElement('div');
    row.className='task-row'+(task.done?' done':'');
    row.innerHTML=`<button class="task-check" title="Terminer">${task.done?'✓':''}</button><div class="task-text"><div>${task.text}</div><div class="task-meta">${task.created}</div></div><button class="btn task-del" title="Supprimer"><i data-lucide="trash-2"></i></button>`;
    row.querySelector('.task-check').onclick=()=>focusToggleTask(task.id);
    row.querySelector('.task-del').onclick=()=>focusDeleteTask(task.id);
    list.appendChild(row);
  });
  const remaining=focusState.tasks.filter(t=>!t.done).length;
  stats.textContent=`${remaining} tâche${remaining>1?'s':''} · ${focusState.minutes} min focus`;
  lucide.createIcons();
}

function focusSetMode(mode){
  focusState.mode=mode;
  focusState.total=focusDurations[mode];
  focusState.left=focusState.total;
  focusState.running=false;
  clearInterval(focusInterval);
  focusInterval=null;
  focusSave();
  focusRender();
}

function focusToggleTimer(){
  focusState.running=!focusState.running;
  if(focusState.running){
    clearInterval(focusInterval);
    focusInterval=setInterval(()=>{
      focusState.left=Math.max(0,focusState.left-1);
      if(focusState.mode==='focus'&&focusState.left%60===0)focusState.minutes++;
      if(focusState.left<=0){
        clearInterval(focusInterval);
        focusInterval=null;
        focusState.running=false;
        toast(focusState.mode==='focus'?'Session terminée ✓':'Pause terminée');
      }
      focusSave();
      focusRender();
    },1000);
  }else{
    clearInterval(focusInterval);
    focusInterval=null;
  }
  focusSave();
  focusRender();
}

function focusResetTimer(){
  clearInterval(focusInterval);
  focusInterval=null;
  focusState.running=false;
  focusState.left=focusState.total;
  focusSave();
  focusRender();
}

function focusAddTask(){
  const input=document.getElementById('focusInput');
  const text=input.value.trim();
  if(!text)return;
  focusState.tasks.unshift({id:Date.now(),text,done:false,created:new Date().toLocaleDateString('fr-FR',{day:'2-digit',month:'short'})});
  input.value='';
  focusSave();
  focusRender();
}

function focusToggleTask(id){
  const task=focusState.tasks.find(t=>t.id===id);
  if(task)task.done=!task.done;
  focusSave();
  focusRender();
}

function focusDeleteTask(id){
  focusState.tasks=focusState.tasks.filter(t=>t.id!==id);
  focusSave();
  focusRender();
}

