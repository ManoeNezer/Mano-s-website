  const hint=document.createElement('div');hint.style.cssText='font-size:.75rem;color:var(--text-dim);margin-top:8px;';hint.innerText='← → = Déplacer · Espace = Tirer';wrap.appendChild(hint);
  let px=W/2,py=H-40,bullets=[],aliens=[],alienDir=1,alienY=30,score=0,lives=3,running=true,alienBullets=[],alienTimer=0;
  function makeAliens(){
    aliens=[];
    for(let r=0;r<4;r++)for(let c=0;c<9;c++){aliens.push({x:60+c*44,y:60+r*36,alive:true,type:r<1?2:r<3?1:0});}
  }
  makeAliens();
  const keys={};
  gameKeyHandler=e=>{keys[e.key]=e.type==='keydown';if(e.key===' '){e.preventDefault();if(bullets.length<3)bullets.push({x:px,y:py-18});}};
  document.addEventListener('keydown',gameKeyHandler);
  gameKeyupHandler=e=>{keys[e.key]=false;};
  document.addEventListener('keyup',gameKeyupHandler);
  addGameControls(wrap,{actions:[{label:'Tir',key:' '}],pause:false});
  function loop(){
    ctx.fillStyle='rgba(0,0,0,0.3)';ctx.fillRect(0,0,W,H);
    const ac=getComputedStyle(document.body).getPropertyValue('--accent').trim()||'#4f96ff';
    if(!running){ctx.fillStyle='white';ctx.font='bold 28px Syne,sans-serif';ctx.textAlign='center';ctx.fillText(score===0?'Game Over':'Game Over · '+score+' pts',W/2,H/2);return;}
    if(keys['ArrowLeft']||keys['a'])px=Math.max(20,px-5);
    if(keys['ArrowRight']||keys['d'])px=Math.min(W-20,px+5);
    bullets=bullets.filter(b=>b.y>0);bullets.forEach(b=>{b.y-=6;});
    alienBullets=alienBullets.filter(b=>b.y<H);alienBullets.forEach(b=>{b.y+=3;});
    alienTimer++;if(alienTimer>60){alienTimer=0;const live=aliens.filter(a=>a.alive);if(live.length){const ab=live[Math.floor(Math.random()*live.length)];alienBullets.push({x:ab.x,y:ab.y+14});}}
    // alien movement
    let edge=false;aliens.forEach(a=>{if(!a.alive)return;a.x+=alienDir*1.2;if(a.x>W-30||a.x<30)edge=true;});
    if(edge){alienDir*=-1;aliens.forEach(a=>a.y+=16);if(aliens.some(a=>a.alive&&a.y>H-80)){running=false;}}
    // collision bullets->aliens
    bullets.forEach(b=>{aliens.forEach(a=>{if(!a.alive)return;if(Math.abs(b.x-a.x)<18&&Math.abs(b.y-a.y)<14){a.alive=false;b.y=-1;score+=a.type===2?30:a.type===1?20:10;}});});
    // collision alienBullets->player
    alienBullets.forEach(b=>{if(Math.abs(b.x-px)<16&&Math.abs(b.y-py)<14){b.y=H+1;lives--;if(lives<=0){running=false;toast('Game Over · '+score+' pts');}}});
    if(aliens.every(a=>!a.alive)){makeAliens();alienY=30;score+=200;toast('Vague suivante!');}
    // draw player
    ctx.fillStyle=ac;ctx.shadowColor=ac;ctx.shadowBlur=10;
    ctx.beginPath();ctx.moveTo(px,py-16);ctx.lineTo(px-18,py+10);ctx.lineTo(px+18,py+10);ctx.closePath();ctx.fill();ctx.shadowBlur=0;
    // draw aliens
    aliens.forEach(a=>{
      if(!a.alive)return;
      const ico=a.type===2?'👾':a.type===1?'🛸':'👻';
      ctx.font='20px serif';ctx.textAlign='center';ctx.fillText(ico,a.x,a.y+8);
    });
    // bullets
    ctx.fillStyle=ac;bullets.forEach(b=>{ctx.beginPath();ctx.arc(b.x,b.y,3,0,Math.PI*2);ctx.fill();});
    ctx.fillStyle='#ff6b6b';alienBullets.forEach(b=>{ctx.beginPath();ctx.arc(b.x,b.y,3,0,Math.PI*2);ctx.fill();});
    // HUD
    ctx.fillStyle='white';ctx.font='14px Space Mono,monospace';ctx.textAlign='left';ctx.fillText('Score: '+score,8,18);
    ctx.textAlign='right';ctx.fillText('❤'.repeat(lives),W-8,18);
  }
  startRafLoop(loop,60);
}

// ===== PAC-MAN (simplified) =====
function launchPacman(wrap){
  const TILE=20,COLS=19,ROWS=15;
  const MAP_STR=[
    '###################',
    '#........#........#',
    '#.##.###.#.###.##.#',
    '#.##.###.#.###.##.#',
    '#.................#',
    '#.##.#.#####.#.##.#',
    '#.##.#.#####.#.##.#',
    '#....#...#...#....#',
    '####.###.#.###.####',
    '####.#.......#.####',
    '####.#.#####.#.####',
    '#........#........#',
    '#.##.###.#.###.##.#',
    '#..#.....P.....#..#',
    '###################',
  ];
  let px,py,pdir,nextDir,dots,score=0,lives=3,ghosts=[],running=true,scared=false,scaredT=0;
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='🟡 Pac-Man';wrap.appendChild(titleEl);
  const canvas=document.createElement('canvas');canvas.id='pacCanvas';canvas.width=COLS*TILE;canvas.height=ROWS*TILE;wrap.appendChild(canvas);
  const ctx=canvas.getContext('2d');
  const hint=document.createElement('div');hint.style.cssText='font-size:.75rem;color:var(--text-dim);margin-top:8px;';hint.innerText='Flèches = Déplacer · Mange tous les points!';wrap.appendChild(hint);

  function init(){
    const map=MAP_STR.map(r=>r.split(''));
    dots=[];
    map.forEach((row,r)=>row.forEach((c,col)=>{if(c==='.')dots.push({x:col,y:r});if(c==='P'){px=col;py=r;map[r][col]='.';};}));
    pdir={x:0,y:0};nextDir={x:1,y:0};
    ghosts=[
      {x:9,y:7,dx:1,dy:0,c:'#ff6b6b'},{x:9,y:6,dx:-1,dy:0,c:'#fb923c'},
      {x:8,y:7,dx:0,dy:1,c:'#f472b6'},{x:10,y:7,dx:0,dy:-1,c:'#22d3ee'}
    ];
    score=0;lives=3;
    return map;
  }
  let map=init();
  const keys={};
  gameKeyHandler=e=>{
    const d={ArrowLeft:{x:-1,y:0},ArrowRight:{x:1,y:0},ArrowUp:{x:0,y:-1},ArrowDown:{x:0,y:1}};
    if(d[e.key]){nextDir=d[e.key];e.preventDefault();}
  };
  document.addEventListener('keydown',gameKeyHandler);
  addGameControls(wrap,{pause:false});
  let frame=0;
  function isFree(x,y,dx,dy){const nx=x+dx,ny=y+dy;return nx>=0&&nx<COLS&&ny>=0&&ny<ROWS&&map[ny][nx]!=='#';}
  function loop(){
    frame++;
    if(frame%8===0){
      if(isFree(px,py,nextDir.x,nextDir.y)){pdir=nextDir;}
      if(isFree(px,py,pdir.x,pdir.y)){px+=pdir.x;py+=pdir.y;}
      const di=dots.findIndex(d=>d.x===px&&d.y===py);
      if(di>=0){dots.splice(di,1);score+=10;}
      if(dots.length===0){running=false;toast('🎉 Gagné ! Score: '+score);}
      // move ghosts
      ghosts.forEach(g=>{
        if(frame%16!==0)return;
        const dirs=[{x:1,y:0},{x:-1,y:0},{x:0,y:1},{x:0,y:-1}].filter(d=>isFree(g.x,g.y,d.x,d.y)&&!(d.x===-g.dx&&d.y===-g.dy));
        if(dirs.length){const d=dirs[Math.floor(Math.random()*dirs.length)];g.dx=d.x;g.dy=d.y;}
        if(isFree(g.x,g.y,g.dx,g.dy)){g.x+=g.dx;g.y+=g.dy;}
        if(Math.abs(g.x-px)<=1&&Math.abs(g.y-py)<=1){lives--;if(lives<=0){running=false;toast('💀 Game Over · '+score+' pts');}else{px=9;py=13;pdir={x:0,y:0};}}
      });
    }
    // draw
    ctx.fillStyle='#0a0a18';ctx.fillRect(0,0,COLS*TILE,ROWS*TILE);
    const ac=getComputedStyle(document.body).getPropertyValue('--accent').trim()||'#4f96ff';
    map.forEach((row,r)=>row.forEach((c,col)=>{
