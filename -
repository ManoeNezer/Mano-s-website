function launchTicTacToe(wrap){
  let board=Array(9).fill('');let turn='X';let gameOver=false;
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='❌ Morpion';wrap.appendChild(titleEl);
  const status=document.createElement('div');status.style.cssText='font-size:.9rem;color:var(--text-dim);margin-bottom:12px;';status.innerText='À ton tour — Tu joues ✕';wrap.appendChild(status);
  const boardEl=document.createElement('div');boardEl.className='ttt-board';wrap.appendChild(boardEl);
  const resetBtn=document.createElement('button');resetBtn.className='btn ac';resetBtn.style.marginTop='14px';resetBtn.innerText='↺ Nouvelle partie';resetBtn.onclick=init;wrap.appendChild(resetBtn);

  function init(){board=Array(9).fill('');turn='X';gameOver=false;status.innerText='À ton tour — Tu joues ✕';render();}
  function render(){
    boardEl.innerHTML='';
    board.forEach((v,i)=>{
      const cell=document.createElement('div');cell.className='ttt-cell'+(v?' filled':'');
      cell.innerText=v==='X'?'✕':v==='O'?'○':'';
      cell.style.color=v==='X'?'var(--accent)':'rgba(255,150,100,0.9)';
      if(!v&&!gameOver)cell.onclick=()=>play(i);
      boardEl.appendChild(cell);
    });
    const wins=checkWin();
    if(wins){wins.forEach(i=>boardEl.children[i].classList.add('win'));gameOver=true;status.innerText=turn==='X'?'🎉 Tu as gagné !':`🤖 L'IA a gagné !`;}
    else if(board.every(v=>v)){gameOver=true;status.innerText='🤝 Match nul !';}
  }
  function play(i){if(board[i]||gameOver||turn!=='X')return;board[i]='X';turn='O';render();if(!gameOver)setTimeout(aiMove,320);}
  function aiMove(){
    const best=minimax(board,'O');board[best.idx]='O';turn='X';render();
  }
  function checkWin(){
    const lines=[[0,1,2],[3,4,5],[6,7,8],[0,3,6],[1,4,7],[2,5,8],[0,4,8],[2,4,6]];
    for(const l of lines)if(board[l[0]]&&board[l[0]]===board[l[1]]&&board[l[1]]===board[l[2]])return l;
    return null;
  }
  function score(){const w=checkWin();if(w)return board[w[0]]==='O'?10:-10;if(board.every(v=>v))return 0;return null;}
  function minimax(b,player){
    const s=score();if(s!==null)return{score:s};
    const moves=[];
    b.forEach((v,i)=>{if(!v){b[i]=player;const sub=minimax(b,player==='O'?'X':'O');moves.push({idx:i,score:sub.score});b[i]='';}});
    return moves.reduce((best,m)=>player==='O'?m.score>best.score?m:best:m.score<best.score?m:best,moves[0]);
  }
  init();gameKeyHandler=()=>{};
}

