let mdFocused = false;

function mdRender(){
  let src = document.getElementById('mdInput').value;

  // Stats
  const words = src.trim() ? src.trim().split(/\s+/).length : 0;
  const readTime = Math.max(1, Math.ceil(words / 200));
  document.getElementById('mdStats').innerText = `${words.toLocaleString()} mot${words!==1?'s':''} · ${readTime} min de lecture`;

  let html = src
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    // Fenced code blocks
    .replace(/```(\w*)\n?([\s\S]*?)```/gm,(_,lang,code)=>`<pre class="code-block" data-lang="${lang||'code'}"><code>${code.trim()}</code></pre>`)
    // Inline code
    .replace(/`([^`\n]+)`/g,'<code class="inline-code">$1</code>')
    // Headers
    .replace(/^######\s(.+)$/gm,'<h6>$1</h6>')
    .replace(/^#####\s(.+)$/gm,'<h5>$1</h5>')
    .replace(/^####\s(.+)$/gm,'<h4>$1</h4>')
    .replace(/^###\s(.+)$/gm,'<h3>$1</h3>')
    .replace(/^##\s(.+)$/gm,'<h2>$1</h2>')
    .replace(/^#\s(.+)$/gm,'<h1>$1</h1>')
    // Text styles
    .replace(/\*\*\*(.+?)\*\*\*/g,'<strong><em>$1</em></strong>')
    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.+?)\*/g,'<em>$1</em>')
    .replace(/~~(.+?)~~/g,'<del>$1</del>')
    // Blockquote
    .replace(/^>\s(.+)$/gm,'<blockquote>$1</blockquote>')
    // HR
    .replace(/^(---|\*\*\*|___)$/gm,'<hr class="md-hr">')
    // Images before links
    .replace(/!\[([^\]]*)\]\(([^)]+)\)/g,'<img src="$2" alt="$1" class="md-img">')
    // Links
    .replace(/\[([^\]]+)\]\(([^)]+)\)/g,'<a href="$2" target="_blank" rel="noopener">$1</a>');

  // Tables (GFM)
  html = html.replace(/^(\|.+\|[ \t]*)\n\|[-:| \t]+\|\n((?:\|.+\|[ \t]*\n?)*)/gm, (m, headerLine, bodyLines) => {
    const ths = headerLine.split('|').filter(c=>c.trim()).map(c=>`<th>${c.trim()}</th>`).join('');
    const rows = bodyLines.trim().split('\n').map(row => {
      const tds = row.split('|').filter(c=>c.trim()).map(c=>`<td>${c.trim()}</td>`).join('');
      return `<tr>${tds}</tr>`;
    }).join('');
    return `<div class="md-table-wrap"><table><thead><tr>${ths}</tr></thead><tbody>${rows}</tbody></table></div>`;
  });

  // Unordered lists
  html = html.replace(/((?:^[-*+]\s.+\n?)+)/gm, block => {
    const items = block.trim().split('\n').map(l=>`<li>${l.replace(/^[-*+]\s/,'')}</li>`).join('');
    return `<ul>${items}</ul>`;
  });
  // Ordered lists
  html = html.replace(/((?:^\d+\.\s.+\n?)+)/gm, block => {
    const items = block.trim().split('\n').map(l=>`<li>${l.replace(/^\d+\.\s/,'')}</li>`).join('');
    return `<ol>${items}</ol>`;
  });

  // Paragraphs for non-tagged lines
  html = html.split('\n').map(line => {
    const trimmed = line.trim();
    if (!trimmed) return '';
    if (trimmed.startsWith('<')) return line;
    return `<p>${line}</p>`;
  }).join('\n');

  // Clean
  html = html.replace(/<p><\/p>/g,'').replace(/<p>\s*<\/p>/g,'');

  document.getElementById('mdPrev').innerHTML = html;
}

