let converterReady=false;

function converterInit(){
  if(!converterReady){
    converterReady=true;
    converterRenderUnits();
    converterRenderQuick();
  }
  converterCalc();
}

function converterRenderUnits(){
  const cat=document.getElementById('convCategory')?.value||'length';
  const data=CONVERTER_UNITS[cat];
  const from=document.getElementById('convFrom');
  const to=document.getElementById('convTo');
  if(!from||!to)return;
  const prevFrom=from.value,prevTo=to.value;
  const options=Object.entries(data.units).map(([key,u])=>`<option value="${key}">${u.label} (${u.symbol})</option>`).join('');
  from.innerHTML=options;
  to.innerHTML=options;
  from.value=data.units[prevFrom]?prevFrom:data.defaultFrom;
  to.value=data.units[prevTo]?prevTo:data.defaultTo;
}

function converterConvert(value,cat,from,to){
  const data=CONVERTER_UNITS[cat];
  if(cat==='temperature')return data.fromBase(data.toBase(value,from),to);
  return value*data.units[from].factor/data.units[to].factor;
}

function converterFormat(value){
  if(!Number.isFinite(value))return '—';
  const abs=Math.abs(value);
  if(abs!==0&&(abs>=1e9||abs<0.000001))return value.toExponential(6).replace('.',',');
  return new Intl.NumberFormat('fr-FR',{maximumFractionDigits:8}).format(value);
}

function converterCalc(){
  const value=Number(document.getElementById('convValue')?.value||0);
  const cat=document.getElementById('convCategory')?.value||'length';
  const from=document.getElementById('convFrom')?.value||CONVERTER_UNITS[cat].defaultFrom;
  const to=document.getElementById('convTo')?.value||CONVERTER_UNITS[cat].defaultTo;
  const result=converterConvert(value,cat,from,to);
  const fromUnit=CONVERTER_UNITS[cat].units[from];
  const toUnit=CONVERTER_UNITS[cat].units[to];
  const formula=`${converterFormat(value)} ${fromUnit.symbol} =`;
  const resText=`${converterFormat(result)} ${toUnit.symbol}`;
  document.getElementById('convFormula').textContent=formula;
  document.getElementById('convResult').textContent=resText;
  return {formula,result:resText};
}

function converterSwap(){
  const from=document.getElementById('convFrom');
  const to=document.getElementById('convTo');
  [from.value,to.value]=[to.value,from.value];
  converterCalc();
}

function converterSetValue(value){
  document.getElementById('convValue').value=value;
