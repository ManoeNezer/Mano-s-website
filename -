function launchMinesweeper(wrap){
  const COLS=16,ROWS=12,MINES=28;
  let board=[],revealed=[],flagged=[],minePos=[],started=false,gameOver=false,remaining=0;
  const titleEl=document.createElement('div');titleEl.className='gametitle';titleEl.innerHTML='💣 Démineur';wrap.appendChild(titleEl);
