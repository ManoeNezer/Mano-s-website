let plotState={xMin:-10,xMax:10,yMin:null,yMax:null,expr:'sin(x)',dragging:false,dragStart:null,viewDragStart:null};

function doPlot(expr){
  const raw=(typeof expr==='string'?expr:document.getElementById('plotIn').value.trim());
  plotState.expr=raw.replace(/f\(x\)\s*=/,'').replace(/y\s*=/,'').trim()||'sin(x)';
  renderPlot();
}
function renderPlot(){
  const canvas=document.getElementById('plotCanvas');
  const ctx=canvas.getContext('2d');
  canvas.width=canvas.offsetWidth||500;
  canvas.height=canvas.offsetHeight||200;
  const W=canvas.width,H=canvas.height;
  const {xMin,xMax,expr}=plotState;
  const steps=W*3;
  ctx.clearRect(0,0,W,H);

  // Compute Y range if not set
  if(!plotState.yMin||!plotState.yMax){
    const ys=[];
    for(let i=0;i<=steps;i++){const x=xMin+(xMax-xMin)*i/steps;try{const y=math.evaluate(expr,{x});if(isFinite(y))ys.push(y);}catch{}}
    if(!ys.length){toast('Expression invalide');return;}
    const ySpan=Math.max(...ys)-Math.min(...ys)||1;
    plotState.yMin=Math.min(...ys)-ySpan*0.12;
    plotState.yMax=Math.max(...ys)+ySpan*0.12;
  }
  const {yMin,yMax}=plotState;
  const toX=x=>(x-xMin)/(xMax-xMin)*W;
  const toY=y=>H-(y-yMin)/(yMax-yMin)*H;

  // Grid lines
  ctx.strokeStyle='rgba(255,255,255,.06)';ctx.lineWidth=1;
  const xStep=niceStep((xMax-xMin)/8);
  const yStep=niceStep((yMax-yMin)/6);
  for(let x=Math.ceil(xMin/xStep)*xStep;x<=xMax;x+=xStep){ctx.beginPath();ctx.moveTo(toX(x),0);ctx.lineTo(toX(x),H);ctx.stroke();}
  for(let y=Math.ceil(yMin/yStep)*yStep;y<=yMax;y+=yStep){ctx.beginPath();ctx.moveTo(0,toY(y));ctx.lineTo(W,toY(y));ctx.stroke();}

  // Axes
  ctx.strokeStyle='rgba(255,255,255,.28)';ctx.lineWidth=1.5;
  if(xMin<=0&&xMax>=0){ctx.beginPath();ctx.moveTo(toX(0),0);ctx.lineTo(toX(0),H);ctx.stroke();}
  if(yMin<=0&&yMax>=0){ctx.beginPath();ctx.moveTo(0,toY(0));ctx.lineTo(W,toY(0));ctx.stroke();}

  // Labels
  ctx.fillStyle='rgba(255,255,255,.32)';ctx.font='10px Space Mono,monospace';ctx.textAlign='center';
  for(let x=Math.ceil(xMin/xStep)*xStep;x<=xMax;x+=xStep){
    if(Math.abs(x)<xStep*0.01)continue;
    const px=toX(x),py=Math.max(14,Math.min(H-4,toY(0)+14));
    ctx.fillText(x%1===0?x:x.toFixed(1),px,py);
  }
  ctx.textAlign='right';
  for(let y=Math.ceil(yMin/yStep)*yStep;y<=yMax;y+=yStep){
    if(Math.abs(y)<yStep*0.01)continue;
    const py=toY(y),px=Math.max(30,Math.min(W-4,toX(0)-4));
    ctx.fillText(y%1===0?y:y.toFixed(1),px,py+4);
  }

  // Curve with glow
  const ac=getComputedStyle(document.body).getPropertyValue('--accent').trim()||'#4f96ff';
  ctx.shadowColor=ac;ctx.shadowBlur=12;
  ctx.strokeStyle=ac;ctx.lineWidth=2.5;
  ctx.beginPath();let first=true;
  for(let i=0;i<=steps;i++){
    const x=xMin+(xMax-xMin)*i/steps;
    try{
      const y=math.evaluate(expr,{x});
      if(!isFinite(y)){first=true;continue;}
      const px=toX(x),py=toY(y);
      if(py<-H*2||py>H*3){first=true;continue;}
      first?ctx.moveTo(px,py):ctx.lineTo(px,py);first=false;
    }catch{first=true;}
  }
  ctx.stroke();ctx.shadowBlur=0;

  // Info
  const rangeX=(xMax-xMin).toFixed(2),centerX=((xMin+xMax)/2).toFixed(2);
  document.getElementById('plotInfo').innerText=`x:[${xMin.toFixed(1)},${xMax.toFixed(1)}] · Scroll:zoom · Drag:pan`;
}
function niceStep(raw){
  const mag=Math.pow(10,Math.floor(Math.log10(raw)));
  const norm=raw/mag;
  if(norm<1.5)return mag;
  if(norm<3.5)return 2*mag;
  if(norm<7.5)return 5*mag;
  return 10*mag;
}
function resetPlotView(){
  plotState.xMin=-10;plotState.xMax=10;plotState.yMin=null;plotState.yMax=null;
  renderPlot();
}
// Plot interaction
(function(){
  setTimeout(()=>{
    const canvas=document.getElementById('plotCanvas');
    // Wheel = zoom
    canvas.addEventListener('wheel',e=>{
      e.preventDefault();
      const rect=canvas.getBoundingClientRect();
      const mx=(e.clientX-rect.left)/rect.width;
      const {xMin,xMax,yMin,yMax}=plotState;
      const xRange=xMax-xMin,yRange=(yMax||10)-(yMin||-10);
      const factor=e.deltaY>0?1.18:0.85;
      const cx=xMin+mx*xRange;
      const cy=(yMin||0)+(1-(e.clientY-rect.top)/rect.height)*yRange;
      plotState.xMin=cx-(cx-xMin)*factor;
      plotState.xMax=cx+(xMax-cx)*factor;
      plotState.yMin=cy-(cy-(yMin||0))*factor;
      plotState.yMax=cy+((yMax||10)-cy)*factor;
      renderPlot();
    },{passive:false});
    // Drag = pan
    canvas.addEventListener('mousedown',e=>{
      plotState.dragging=true;
      plotState.dragStart={x:e.clientX,y:e.clientY};
      plotState.viewDragStart={xMin:plotState.xMin,xMax:plotState.xMax,yMin:plotState.yMin||0,yMax:plotState.yMax||10};
    });
    canvas.addEventListener('mousemove',e=>{
      if(!plotState.dragging)return;
      const dx=e.clientX-plotState.dragStart.x;
      const dy=e.clientY-plotState.dragStart.y;
      const W=canvas.offsetWidth||500,H=canvas.offsetHeight||200;
      const {xMin,xMax,yMin,yMax}=plotState.viewDragStart;
      const xRange=xMax-xMin,yRange=yMax-yMin;
      plotState.xMin=xMin-dx/W*xRange;
      plotState.xMax=xMax-dx/W*xRange;
      plotState.yMin=yMin+dy/H*yRange;
      plotState.yMax=yMax+dy/H*yRange;
      renderPlot();
    });
    canvas.addEventListener('mouseup',()=>{plotState.dragging=false;});
    canvas.addEventListener('mouseleave',()=>{plotState.dragging=false;});
    // Touch support
    let lastTouchDist=null;
    canvas.addEventListener('touchstart',e=>{
      if(e.touches.length===1){
        plotState.dragging=true;
        plotState.dragStart={x:e.touches[0].clientX,y:e.touches[0].clientY};
        plotState.viewDragStart={xMin:plotState.xMin,xMax:plotState.xMax,yMin:plotState.yMin||0,yMax:plotState.yMax||10};
      }else if(e.touches.length===2){
        lastTouchDist=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
      }
      e.preventDefault();
    },{passive:false});
    canvas.addEventListener('touchmove',e=>{
      if(e.touches.length===1&&plotState.dragging){
        const dx=e.touches[0].clientX-plotState.dragStart.x;
        const dy=e.touches[0].clientY-plotState.dragStart.y;
        const W=canvas.offsetWidth||500,H=canvas.offsetHeight||200;
        const {xMin,xMax,yMin,yMax}=plotState.viewDragStart;
        const xRange=xMax-xMin,yRange=yMax-yMin;
        plotState.xMin=xMin-dx/W*xRange;plotState.xMax=xMax-dx/W*xRange;
        plotState.yMin=yMin+dy/H*yRange;plotState.yMax=yMax+dy/H*yRange;
        renderPlot();
      }else if(e.touches.length===2&&lastTouchDist){
        const dist=Math.hypot(e.touches[0].clientX-e.touches[1].clientX,e.touches[0].clientY-e.touches[1].clientY);
        const factor=lastTouchDist/dist;
        const cx=(plotState.xMin+plotState.xMax)/2,cy=((plotState.yMin||0)+(plotState.yMax||10))/2;
        const xRange=(plotState.xMax-plotState.xMin)*factor,yRange=((plotState.yMax||10)-(plotState.yMin||0))*factor;
        plotState.xMin=cx-xRange/2;plotState.xMax=cx+xRange/2;
        plotState.yMin=cy-yRange/2;plotState.yMax=cy+yRange/2;
        lastTouchDist=dist;
        renderPlot();
      }
      e.preventDefault();
    },{passive:false});
    canvas.addEventListener('touchend',()=>{plotState.dragging=false;lastTouchDist=null;});
  },800);
})();
