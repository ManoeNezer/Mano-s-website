let activeInterval=null,activeRaf=null,activeTimeout=null;
let gameKeyHandler=()=>{},gameKeyupHandler=()=>{};
function stopAllGames(){
  if(activeInterval){clearInterval(activeInterval);activeInterval=null;}
  if(activeRaf){cancelAnimationFrame(activeRaf);activeRaf=null;}
  if(activeTimeout){clearTimeout(activeTimeout);activeTimeout=null;}
  document.removeEventListener('keydown',gameKeyHandler);
  document.removeEventListener('keyup',gameKeyupHandler);
  gameKeyHandler=()=>{};gameKeyupHandler=()=>{};
}
function startRafLoop(step,fps=60){
  const frameMs=1000/fps;
  let last=0;
  const frame=ts=>{
    if(!last||ts-last>=frameMs){
      last=ts;
      step(ts);
    }
    activeRaf=requestAnimationFrame(frame);
  };
  activeRaf=requestAnimationFrame(frame);
}

function gameKey(key,type='keydown'){
